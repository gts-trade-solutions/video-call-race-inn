# ---------- MySQL ----------
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="race@123"
DB_NAME=video_call_tool

# ---------- Auth ----------
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-string

# ---------- LiveKit ----------
# Get free credentials at https://cloud.livekit.io (or self-host).
# LIVEKIT_URL is the wss:// server url. The NEXT_PUBLIC_ copy is used by the browser.
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# ---------- Recording → Amazon S3 (optional) ----------
# Enables the in-call "Record" button. Meetings are recorded by LiveKit Egress
# (server-side, room composite MP4) and uploaded straight to this S3 bucket.
# Egress must be available: it's built in on LiveKit Cloud; self-hosters must run
# the egress service (https://docs.livekit.io/home/self-hosting/egress/).
AWS_S3_BUCKET_NAME=your-recordings-bucket
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=your_aws_access_key_id
AWS_S3_SECRET_ACCESS_KEY=your_aws_secret_access_key
NEXT_PUBLIC_S3_BUCKET_URL=https://your-recordings-bucket.s3.us-east-1.amazonaws.com/
# Optional — for S3-compatible stores (MinIO, Cloudflare R2, Wasabi, …):
# S3_ENDPOINT=https://s3.example.com
# S3_FORCE_PATH_STYLE=true

# ---------- Email / password reset (optional) ----------
# SMTP for "Forgot password" emails (a 4-digit code). If unset, in dev the code
# is shown on screen instead of emailed (so the flow still works without mail).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@example.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Race Meetings <no-reply@yourdomain.com>"

# ---------- Calendar (optional) ----------
# The public URL of the app, used to build absolute join links inside calendar
# invites and OAuth redirects. Set this behind a proxy; otherwise it's derived
# from the request. e.g. https://meet.yourdomain.com
NEXT_PUBLIC_APP_URL=

# Google Calendar sync (optional). Leave blank to hide the "Connect Google
# Calendar" button — Add-to-Calendar links + .ics still work without this.
# Create an OAuth client (type: Web application) at
# https://console.cloud.google.com/apis/credentials, enable the Google Calendar
# API, and add the redirect URI below to the client's "Authorized redirect URIs".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered on the OAuth client:
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback
