# Copy to .env.local on the VPS and fill in real production values.
# NOTE: NEXT_PUBLIC_LIVEKIT_URL must be set BEFORE `npm run build`.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=raceapp
MYSQL_PASSWORD=change-me
DB_NAME=video_call_tool

# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string

LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Recording → Amazon S3 (LiveKit Egress). Leave blank to disable the Record button.
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
NEXT_PUBLIC_S3_BUCKET_URL=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=true

# Public app URL (used for calendar invite links + Google OAuth redirects).
# NOTE: NEXT_PUBLIC_APP_URL is baked in at BUILD time — set it before `npm run build`.
NEXT_PUBLIC_APP_URL=https://meetings.raceinnovations.in

# Google Sign-In + Calendar (one OAuth client). Register BOTH redirect URIs
# below on the client in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SIGNIN_REDIRECT_URI=https://meetings.raceinnovations.in/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=https://meetings.raceinnovations.in/api/calendar/google/callback

# Password-reset code emails via Amazon SES (reuses the AWS S3 creds above).
# SES_FROM must be a verified SES sender. enquiry@raceinnovations.in is already
# verified; to use no-reply@raceinnovations.in, verify that address (or the
# whole raceinnovations.in domain) in SES first.
SES_FROM="Race Meetings <enquiry@raceinnovations.in>"
AWS_SES_REGION=ap-south-1
# --- or SMTP instead of SES ---
# SMTP_SERVICE=gmail
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_16_char_app_password
